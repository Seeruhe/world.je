          "key": "rootPath",
          "label": "根目录路径",
          "type": "string",
          "required": false,
          "default": "/",
          "description": "限制文件操作的范围"
        },
        {
          "key": "allowDelete",
          "label": "允许删除文件",
          "type": "boolean",
          "required": false,
          "default": false
        }
      ],
      "installed": false
    },
