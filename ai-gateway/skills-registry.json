      "id": "skill-file-manager",
      "name": "文件管理",
      "description": "浏览、读取、写入本地或远程文件系统",
      "version": "1.0.0",
      "author": "OpenClaw Team",
      "category": "file-system",
      "icon": "folder",
      "type": "npm",
      "npmPackage": "@openclaw/skill-file-manager",
      "executionMode": "hybrid",
